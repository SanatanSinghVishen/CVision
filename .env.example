# Frontend (Vite)
VITE_SUPABASE_URL=your_supabase_project_url
VITE_SUPABASE_ANON_KEY=your_supabase_anon_key
VITE_API_URL=http://localhost:3000

# Backend
GROQ_API_KEY=your_groq_api_key
SUPABASE_URL=your_supabase_project_url
SUPABASE_SERVICE_ROLE_KEY=your_supabase_service_role_key
ALLOWED_ORIGIN=http://localhost:5173

# Upstash Redis — REST client (rate limiting + caching)
UPSTASH_REDIS_REST_URL=https://your-instance.upstash.io
UPSTASH_REDIS_REST_TOKEN=your-token-here

# Upstash Redis — TCP client (BullMQ job queue)
UPSTASH_REDIS_URL=rediss://default:your-password@your-instance.upstash.io:6379

# Job queue config
ANALYSIS_JOB_TIMEOUT_MS=45000
ANALYSIS_JOB_MAX_RETRIES=3